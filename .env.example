# Copiar este archivo como .env y completar los valores reales
# El archivo .env NUNCA debe subirse al repositorio

# Credenciales de Oracle
DB_USER=tu_usuario
DB_PASSWORD=tu_contrasena
DB_HOST=tu_host_o_ip
DB_PORT=1521
DB_SERVICE_NAME=tu_service_name

# Ruta al Oracle Instant Client (thick mode obligatorio para Oracle 11g/12c)
# Ejemplo Windows: C:\oracle\instantclient_21_3
ORACLE_CLIENT_PATH=C:\oracle\instantclient_21_3

# Directorio donde se guardan los Excel generados (default: carpeta del proyecto)
OUTPUT_DIR=.

# ── AXTRACT (NBI API GPON) ───────────────────────────────────────────────────
# Basic Auth para la API REST de AXTRACT (store: cpe_store — ONTs GPON)
AXTRACT_URL=http://10.158.222.1:8088/live/nbi_interfaces/rest/v1/action/device_query
AXTRACT_USER=tu_usuario_axtract
AXTRACT_PASSWORD=tu_password_axtract

# ── PNM (NBI API HFC) ────────────────────────────────────────────────────────
# Basic Auth para la API REST de PNM (store: cm_store — cable modems HFC)
PNM_URL=http://10.159.179.17:8088/live/nbi_interfaces/rest/v1/action/device_query
PNM_USER=tu_usuario_pnm
PNM_PASSWORD=tu_password_pnm
